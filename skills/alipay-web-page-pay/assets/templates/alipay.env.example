# ------------------------------
# App profile selection
# ------------------------------
# sandbox | production
ALIPAY_ACTIVE_PROFILE=sandbox

# Common
PORT=8787

# ------------------------------
# Sandbox profile
# ------------------------------
ALIPAY_SANDBOX_APP_ID=
ALIPAY_SANDBOX_PRIVATE_KEY=
ALIPAY_SANDBOX_PUBLIC_KEY=
ALIPAY_SANDBOX_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_SANDBOX_NOTIFY_URL=
ALIPAY_SANDBOX_RETURN_URL=

# ------------------------------
# Production profile
# ------------------------------
ALIPAY_PROD_APP_ID=
ALIPAY_PROD_PRIVATE_KEY=
ALIPAY_PROD_PUBLIC_KEY=
ALIPAY_PROD_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_PROD_NOTIFY_URL=
ALIPAY_PROD_RETURN_URL=

# Optional ISV mode token handling
# ALIPAY_APP_AUTH_TOKEN=

# Optional app-level protection
# APP_KEY=
# CORS_ORIGIN=*
